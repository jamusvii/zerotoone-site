---
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = [
  {
    id: 'pivot-001',
    type: 'pivot',
    typeLabel: '전환점',
    date: '2025.03.28',
    week: 'W3',
    title: '숨겨진 진실: 문제는 도구가 아니라 의사결정 프레임이었다',
    body: `5개 아이디어를 다 버리고 나서야 보였다. 소상공인들에게 필요한 건 더 많은 데이터가 아니었다. "어떤 것을 고려해서 어떻게 결정할지"를 구조화하는 프레임이 없었다. 우리가 만들어야 할 건 분석 도구가 아니라 의사결정 코치였다.`,
    metrics: [],
    project: 'AI 의사결정 파트너',
    projectSlug: 'ai-decision-partner',
  },
  {
    id: 'kill-005',
    type: 'kill',
    typeLabel: '기각',
    date: '2025.03.22',
    week: 'W2',
    title: '다섯 번째 기각: 스마트 재고관리 SaaS',
    body: `플랫폼 의존성 문제가 또 나왔다. 쿠팡이나 네이버의 API 정책이 바뀌면 서비스가 통째로 흔들린다. 이건 지속가능한 사업이 아니다. 5번째 기각. 이 정도면 방향 자체를 다시 봐야 한다.`,
    metrics: [
      { label: '기각 이유', value: '플랫폼 의존성' },
      { label: '누적 기각', value: '5/5' },
    ],
    project: 'AI 의사결정 파트너',
    projectSlug: 'ai-decision-partner',
  },
  {
    id: 'signal-004',
    type: 'signal',
    typeLabel: '시그널',
    date: '2025.03.14',
    week: 'W1',
    title: 'ChatGPT를 쓰는 소상공인은 늘었지만 결과물 품질은 들쭉날쭉',
    body: `서울 소상공인 20명 인터뷰. 65%가 AI 도구를 써봤지만 "일관성이 없어서" 포기한 경우가 많다. 질문하는 방법을 모르기 때문이다. 이것도 의사결정 프레임 문제다.`,
    metrics: [
      { label: 'AI 도구 사용 경험', value: '65%' },
      { label: '지속 사용률', value: '23%' },
    ],
    project: 'AI 의사결정 파트너',
    projectSlug: 'ai-decision-partner',
  },
  {
    id: 'signal-001',
    type: 'signal',
    typeLabel: '시그널',
    date: '2025.03.08',
    week: 'W1',
    title: '소상공인 72%가 감으로 재고를 결정한다',
    body: `통계청 2024 소상공인 실태조사 + 직접 인터뷰 15건. 데이터 기반 의사결정을 하는 소상공인은 28%에 불과하다. 나머지 72%는 "경험"이라고 불리는 불확실성에 의존한다. 이건 시장이다.`,
    metrics: [
      { label: '감으로 결정', value: '72%' },
      { label: '데이터 기반', value: '28%' },
      { label: '샘플 수', value: 'n=15' },
    ],
    project: 'AI 의사결정 파트너',
    projectSlug: 'ai-decision-partner',
  },
];

const typeColors: Record<string, string> = {
  signal: 'signal',
  kill:   'kill',
  pivot:  'pivot',
  build:  'build',
  revenue:'revenue',
};
---

<BaseLayout
  title="빌드 로그"
  description="Zero to One 빌드 로그. 시그널, 기각, 수익, 실패를 날짜 순으로 공개한다."
>

  <div class="page-header">
    <div class="container">
      <span class="label">빌드 로그 / Build Log</span>
      <h1>과정을 숨기지 않는다.</h1>
      <p class="page-desc">
        시그널, 기각된 아이디어, 수익 수치, 실패까지.<br />
        좋은 것만 골라 보여주는 포트폴리오가 아니다.
      </p>

      <div class="log-legend">
        <span class="legend-item"><span class="ltag ltag--signal">시그널</span> 시장 신호 발견</span>
        <span class="legend-item"><span class="ltag ltag--kill">기각</span> 아이디어 폐기</span>
        <span class="legend-item"><span class="ltag ltag--pivot">전환점</span> 방향 변경</span>
        <span class="legend-item"><span class="ltag ltag--build">빌딩</span> 개발 진행</span>
      </div>
    </div>
  </div>

  <div class="container log-body">
    <div class="log-list">
      {entries.map((entry) => (
        <article class:list={['log-entry', `log-entry--${entry.type}`]} id={entry.id}>
          <div class="log-entry-left">
            <span class="log-week label">{entry.week}</span>
            <span class="log-date label">{entry.date}</span>
            <span class:list={['log-type', `ltag--${entry.type}`, 'ltag']}>{entry.typeLabel}</span>
          </div>

          <div class="log-entry-right">
            <h2 class="log-entry-title">{entry.title}</h2>
            <p class="log-entry-body">{entry.body}</p>

            {entry.metrics.length > 0 && (
              <div class="log-metrics">
                {entry.metrics.map((m) => (
                  <div class="log-metric">
                    <span class="label">{m.label}</span>
                    <span class="metric-val">{m.value}</span>
                  </div>
                ))}
              </div>
            )}

            <div class="log-entry-footer">
              <a href={`/projects/${entry.projectSlug}`} class="log-project-link">
                {entry.project} →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

</BaseLayout>

<style>
  .page-header {
    padding: 7rem 0 4rem;
    border-bottom: 1px solid var(--border);
  }

  .page-header .label {
    display: block;
    margin-bottom: 1.5rem;
  }

  .page-header h1 { margin-bottom: 1rem; }

  .page-desc {
    color: var(--ink-muted);
    font-size: 1.05rem;
    margin-bottom: 3rem;
  }

  .log-legend {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .legend-item {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Tags */
  .ltag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
  }

  .ltag--signal  { background: rgba(13,13,13,0.07);  color: var(--ink-muted); }
  .ltag--kill    { background: rgba(255,59,0,0.08);  color: var(--accent); }
  .ltag--pivot   { background: var(--ink);            color: var(--bg); }
  .ltag--build   { background: rgba(13,13,13,0.12);  color: var(--ink); }
  .ltag--revenue { background: rgba(0,160,80,0.1);   color: #008040; }

  /* ─── Log Body ─────────────────────────────────────── */
  .log-body {
    padding: 5rem 0;
  }

  .log-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .log-entry {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: 3rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
  }

  .log-entry-left {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 0.2rem;
  }

  .log-week {
    font-size: 0.65rem;
    color: var(--ink-faint);
  }

  .log-date { color: var(--ink-muted); }

  .log-entry-title {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .log-entry--kill:hover .log-entry-title { color: var(--accent); }
  .log-entry--pivot:hover .log-entry-title { color: var(--ink); }

  .log-entry-body {
    font-size: 0.95rem;
    color: var(--ink-muted);
    max-width: 60ch;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .log-metrics {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    padding: 1.25rem;
    background: rgba(13,13,13,0.03);
    border-left: 2px solid var(--border);
  }

  .log-metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metric-val {
    font-family: var(--font-mono);
    font-size: 1.2rem;
  }

  .log-entry-footer {}

  .log-project-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
    transition: color 0.15s;
  }

  .log-project-link:hover { color: var(--ink); }

  /* ─── Responsive ──────────────────────────────────── */
  @media (max-width: 640px) {
    .log-entry {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .log-entry-left {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
    }
  }
</style>
